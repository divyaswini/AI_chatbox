{
  "description": "",
  "variables": {
    "chatOpen": {
      "type": "boolean",
      "defaultValue": false
    },
    "chatMessages": {
      "type": "ChatMessage[]",
      "defaultValue": []
    },
    "chatDateLabel": {
      "type": "string",
      "defaultValue": ""
    },
    "isMuted": {
      "type": "boolean",
      "defaultValue": false
    },
    "isTyping": {
      "type": "boolean",
      "defaultValue": false
    },
    "hasOpened": {
      "type": "boolean",
      "defaultValue": false
    }
  },
  "metadata": {},
  "types": {
    "ChatMessage": {
      "id": "string",
      "text": "string",
      "sender": "string",
      "time": "string"
    }
  },
  "eventListeners": {
    "toggleChat": {
      "chains": [
        {
          "chain": "toggleChat"
        }
      ]
    },
    "toggleMute": {
      "chains": [
        {
          "chain": "toggleMute"
        }
      ]
    },
    "sendMessage": {
      "chains": [
        {
          "chain": "sendMessage"
        }
      ]
    },
    "handleKeyDown": {
      "chains": [
        {
          "parameters": {
            "event": "{{ $event }}"
          },
          "chain": "handleKeyDown"
        }
      ]
    }
  },
  "imports": {
    "components": {
      "oj-c-card": {
        "path": "oj-c/card/loader"
      }
    }
  },
  "translations": {}
}
