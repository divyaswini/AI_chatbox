{
  "title": "Home",
  "description": "",
  "variables": {
    "chatOpen": {
      "type": "boolean",
      "defaultValue": false
    },
    "chatMessages": {
      "type": "ChatMessage[]",
      "defaultValue": [
        {
          "id": "msg-welcome",
          "text": "Hello, I'm Oracle Assistant. What are your questions about Oracle Integration?",
          "sender": "bot",
          "time": "Just now"
        }
      ]
    },
    "chatDateLabel": {
      "type": "string",
      "defaultValue": "TODAY"
    },
    "isMuted": {
      "type": "boolean",
      "defaultValue": false
    }
  },
  "types": {
    "ChatMessage": {
      "id": "string",
      "text": "string",
      "sender": "string",
      "time": "string"
    }
  },
  "chains": {},
  "eventListeners": {
    "vbEnter": {
      "chains": [
        {
          "chain": "initChat"
        }
      ]
    },
    "toggleChat": {
      "chains": [
        {
          "chain": "toggleChat"
        }
      ]
    },
    "toggleMute": {
      "chains": [
        {
          "chain": "toggleMute"
        }
      ]
    },
    "sendMessage": {
      "chains": [
        {
          "chain": "sendMessage"
        }
      ]
    },
    "handleKeyDown": {
      "chains": [
        {
          "parameters": {
            "event": "{{ $event }}"
          },
          "chain": "handleKeyDown"
        }
      ]
    }
  },
  "metadata": {},
  "imports": {}
}
